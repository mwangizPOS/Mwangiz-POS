# MWANGI'Z Salon POS environment template
# Copy the Railway section into Railway project variables.
# Copy the local desktop section into your local .env when developing Electron/Vite.

# ---------------------------------------------------------------------------
# LOCAL DESKTOP / VITE ONLY
# Do not put these in Railway unless you specifically need them there.
# ---------------------------------------------------------------------------

VITE_API_BASE_URL=http://localhost:4000
MWANGI_POS_API_BASE_URL=http://localhost:4000
MWANGI_POS_DEVICE_ID=dev-terminal-1
MWANGI_POS_SYNC_DB_PATH=./mwangi-pos-offline.sqlite

# ---------------------------------------------------------------------------
# RAILWAY BACKEND ENV VARS
# Put these in Railway -> Service -> Variables.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=production
# Railway provides PORT automatically. Use PORT only for local backend runs.
# PORT=4000

# PostgreSQL / Supabase
DATABASE_URL=postgresql://postgres:password@host:5432/database
DATABASE_SSL=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# API security
BACKEND_API_KEY=replace-with-long-random-api-key
JWT_SECRET=replace-with-long-random-jwt-secret
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_DAYS=30

# CORS
# Add the deployed/local Electron app origins that may call the Railway API.
ELECTRON_APP_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Sync tuning
SYNC_BATCH_SIZE=50
SYNC_RETRY_LIMIT=8
SYNC_RETRY_DELAY=1000

# Safaricom Daraja / M-Pesa
# DARAJA_* is the business naming from the payment architecture.
# MPESA_* is also kept because current backend modules read these names.
# Set matching key/secret values in both pairs until aliases are consolidated.
DARAJA_CONSUMER_KEY=replace-with-daraja-consumer-key
DARAJA_CONSUMER_SECRET=replace-with-daraja-consumer-secret
MPESA_CONSUMER_KEY=replace-with-daraja-consumer-key
MPESA_CONSUMER_SECRET=replace-with-daraja-consumer-secret

MPESA_ENV=sandbox
CALLBACK_BASE_URL=https://your-railway-domain.up.railway.app
MPESA_CALLBACK_URL=https://your-railway-domain.up.railway.app/api/mpesa/callback
MPESA_CALLBACK_SECRET=replace-with-long-random-callback-secret
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Branch-specific values must eventually come from branch configuration.
# Keep these placeholders only for current backend payment modules.
MPESA_SHORTCODE=replace-with-branch-shortcode
MPESA_PASSKEY=replace-with-branch-passkey
